<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient android:angle="0" android:startColor="#F04450" android:endColor="#B90814" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="#80FFFFFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#8F0711" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B31A2533" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#263F5268" />
        </shape>
    </item>
</selector>
