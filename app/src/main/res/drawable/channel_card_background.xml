<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#F04450"
                android:endColor="#B90814" />
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="#B3FFFFFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#9F0711" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#D9111B28"
                android:endColor="#D9172332" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#334F637A" />
        </shape>
    </item>
</selector>
